# Copy this file to `.env` (which is gitignored) and fill in real values.
# Settings.py reads these via os.environ.get() at startup.

# --- Django ---
DJANGO_SECRET_KEY=change-me-locally
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# --- Ollama ---
# To use Ollama Cloud in dev (same as production), point OLLAMA_HOST at
# https://ollama.com, set OLLAMA_API_KEY to a key from
# https://ollama.com/settings/keys, and use a "-cloud" model tag.
# To use a local Ollama daemon instead, leave OLLAMA_API_KEY empty and set
# OLLAMA_HOST=http://localhost:11434 with the non-suffixed model tag.
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=paste-your-key-here
DOCER_DEFAULT_MODEL=gemma4:31b-cloud
DOCER_OLLAMA_TIMEOUT=600

# Retry budget when the model returns non-JSON. Each retry sends a corrective
# turn before re-asking. Set to 1 to disable retries.
DOCER_EXTRACTION_MAX_ATTEMPTS=3

# --- Demo deployment: run Huey worker in-process ---
# When set to 1, the gunicorn process spawns a background Huey consumer thread
# so a single service handles both web requests and scan tasks. Requires
# gunicorn --workers=1. Leave unset for local dev (run `manage.py run_huey`
# in a separate terminal instead).
# DOCER_INPROCESS_HUEY=1
